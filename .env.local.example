# Copy to .env.local and fill in once a real Firebase project exists.
# Until then, leave NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true and run
# `pnpm emulators` — the app works fully against the local emulator
# suite without any of the values below being real.

# --- Client SDK (safe to expose to the browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=demo-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=io2026-builder-board.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=io2026-builder-board
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=io2026-builder-board.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# Set to "true" for local dev against the Firestore + Auth emulators
# (firebase.json). Set to "false"/unset once a real project is wired up.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

# App Check (reCAPTCHA v3 site key). Leave unset while using emulators.
NEXT_PUBLIC_RECAPTCHA_V3_SITE_KEY=

# --- Admin SDK (server-only, Route Handlers) ---
# Full service account JSON as a single-line string. Not required in
# emulator mode (see src/shared/firebase/admin.ts).
FIREBASE_SERVICE_ACCOUNT=

# --- Route Handler secrets ---
# /admin passcode (constant-time compared) — required for the organizer
# console (task #6).
ADMIN_PASSCODE=

# Gemini API key — used only by /api/gemini/* Route Handlers, never
# exposed to the client (task #7).
GEMINI_API_KEY=
