rules_version = '2';

// Skeleton only — real read/write policy (public-read collections, owner
// field whitelist via affectedKeys, likes create-only, cardRecovery
// deny-all) lands in task #2 alongside emulator rule tests.
// See .omc/plans/ralplan-io2026-builder-board.md — "Firestore 보안 규칙".
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
